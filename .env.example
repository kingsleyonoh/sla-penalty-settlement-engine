# Runtime
ASPNETCORE_ENVIRONMENT=Development
PORT=5109
LOG_LEVEL=Information

# Local Docker services
POSTGRES_DB=slapen
POSTGRES_USER=slapen
POSTGRES_PASSWORD=<local-dev-password>
POSTGRES_TEST_DB=slapen_test
LOCAL_POSTGRES_PORT=15432
LOCAL_REDIS_PORT=6386

# Database
DATABASE_URL=Host=localhost;Port=15432;Database=slapen;Username=slapen;Password=<local-dev-password>
TEST_DATABASE_URL=Host=localhost;Port=15432;Database=slapen_test;Username=slapen;Password=<local-dev-password>
DATABASE_POOL=20
AUTO_MIGRATE=true

# Redis
REDIS_URL=redis://localhost:6386/0

# Hangfire
HANGFIRE_SCHEMA=hangfire

# Session / auth
SESSION_SECRET=<random-32-plus-character-session-secret>
SESSION_COOKIE_NAME=slapen_session
SESSION_MAX_AGE_SECONDS=86400

# Tenant management
SELF_REGISTRATION_ENABLED=true
API_KEY_PREFIX=slapen_live_

# CORS
ALLOWED_ORIGINS=https://slapen.kingsleyonoh.com

# Tunables
PENALTY_ROUNDING_MODE=half_even
SETTLEMENT_CADENCE=monthly
SETTLEMENT_DAY_OF_MONTH=1
SETTLEMENT_MAX_RETRIES=5
SETTLEMENT_RETRY_INITIAL_DELAY_SECONDS=30
MAX_OUTBOX_ATTEMPTS=10
OUTBOX_POLL_INTERVAL_SECONDS=10
ACCRUAL_WORKER_CONCURRENCY=4

# Ecosystem - Notification Hub
NOTIFICATION_HUB_ENABLED=false
NOTIFICATION_HUB_URL=https://notify.kingsleyonoh.com
NOTIFICATION_HUB_API_KEY=

# Ecosystem - Workflow Engine
WORKFLOW_ENGINE_ENABLED=false
WORKFLOW_ENGINE_URL=https://workflows.kingsleyonoh.com
WORKFLOW_ENGINE_API_KEY=

# Ecosystem - Contract Lifecycle Engine
CONTRACT_LIFECYCLE_ENABLED=false
CONTRACT_LIFECYCLE_URL=
CONTRACT_LIFECYCLE_API_KEY=
CONTRACT_LIFECYCLE_BACKFILL_INTERVAL_SECONDS=900

# NATS
NATS_ENABLED=false
NATS_URL=nats://localhost:4222
NATS_CREDS_PATH=
NATS_STREAM_NAME=ECOSYSTEM_EVENTS

# Ecosystem - Invoice Reconciliation Engine
INVOICE_RECON_ENABLED=false
INVOICE_RECON_URL=
INVOICE_RECON_API_KEY=

# Ecosystem - VPI
VPI_ENABLED=false
VPI_URL=
VPI_API_KEY=

# Hub ingress
HUB_INGRESS_SECRET=

# Observability
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=slapen-logs
POSTHOG_API_KEY=
POSTHOG_HOST=
PROMETHEUS_ENABLED=true
METRICS_BASIC_AUTH_USER=metrics
METRICS_BASIC_AUTH_PASS=

# Seed automation
AUTO_SEED=true
