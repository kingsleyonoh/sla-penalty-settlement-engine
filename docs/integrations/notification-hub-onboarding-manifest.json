{
  "tenant_name": "sla-penalty-settlement-engine",
  "default_hub_url": "https://notify.kingsleyonoh.com",
  "hub_url_env": "NOTIFICATION_HUB_URL",
  "tenant_api_key_env": "NOTIFICATION_HUB_API_KEY",
  "enabled_env": "NOTIFICATION_HUB_ENABLED",
  "registration_gate": "docs/integrations/notification-hub-registration-gate.md",
  "mode": "local_manifest",
  "live_onboarding_status": "skipped_missing_admin_credentials_and_recipient",
  "tenant_config": {
    "channels": {
      "email": {
        "from": "slapen@notify.klevar.ai",
        "sandbox": true
      }
    }
  },
  "events": [
    {
      "event_type": "penalty.accrued",
      "template_name": "slapen-penalty-accrued-email",
      "channel": "email",
      "recipient_source": "tenant.ops_email",
      "subject": "SLA penalty accrued for {{counterparty_name}}",
      "body_text": "Penalty {{amount}} {{currency}} accrued for {{contract_reference}}."
    },
    {
      "event_type": "settlement.posted",
      "template_name": "slapen-settlement-posted-email",
      "channel": "email",
      "recipient_source": "counterparty.contact.email",
      "subject": "Settlement credit note {{settlement_number}} posted",
      "body_text": "Settlement {{settlement_number}} for {{amount}} {{currency}} was posted."
    },
    {
      "event_type": "breach.pending_attention",
      "template_name": "slapen-breach-pending-digest",
      "channel": "email",
      "recipient_source": "tenant.ops_email",
      "subject": "SLA breaches need attention",
      "body_text": "{{count}} breaches are pending accrual or review."
    },
    {
      "event_type": "breach.disputed_by_counterparty",
      "template_name": "slapen-breach-disputed-email",
      "channel": "email",
      "recipient_source": "tenant.supervisor",
      "subject": "SLA breach dispute opened",
      "body_text": "A dispute was opened for breach {{breach_id}}."
    }
  ],
  "notes": [
    "No admin key, Resend key, tenant API key, recipient address, or delivery callback secret is stored here.",
    "Run live notification-hub-onboard only with credentials supplied through a local environment or vault.",
    "The application client reads all Notification Hub configuration from NOTIFICATION_HUB_* environment variables."
  ]
}
